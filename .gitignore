# Thunity — ignored, regenerable artifacts (repo hygiene). Source/app files stay tracked.

# Frontend dependencies + build output (incl. W14 throwaway verify-build dirs)
frontend/node_modules/
frontend/dist/
frontend/dist_tmp/
frontend/dist_*/
frontend/vite.config.ts.timestamp-*.mjs

# Python / test caches
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
coverage/
.coverage

# OS / editor junk
.DS_Store
__MACOSX/

# Generated archives at repo root only (clean ZIPs etc.)
/*.zip

# Secrets — keep real .env out of version control; template stays tracked
.env
*/.env
!.env.example

# Local runtime data — private company knowledge/uploads/backups stay on-machine
data/files/
data/knowledge/
data/sandbox_runs/
data/backups/

# Local Python virtualenvs
.venv/
venv/

# Claude Code session/memory (never publish)
.claude/

# Dev runtime artifacts: SQLite dev-fallback DB + compose exports default
backend/data/
data/exports/
thunity_dev.db
