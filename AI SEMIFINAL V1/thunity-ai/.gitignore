__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
pytest-cache-files-*
htmlcov/
.coverage
*.cover

# ── Node / Frontend ─────────────────────────────────────────────────
node_modules/
dist/
dist_*/
*.local
frontend/dist/
frontend/dist_*/
