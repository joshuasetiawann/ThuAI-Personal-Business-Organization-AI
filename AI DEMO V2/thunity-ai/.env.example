# ── Thunity Local AI Company OS — LOCAL-ONLY environment template ──
# Copy to .env and replace every CHANGE_ME. NEVER commit the real .env.
# There are intentionally NO OpenAI / Supabase / cloud keys here.

APP_ENV=development
LOCAL_ONLY_MODE=true
SECRET_KEY=change-this-with-strong-random-secret
JWT_EXPIRE_MINUTES=1440
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# First founder is bootstrapped from these (no hardcoded admin/admin123).
FOUNDER_EMAIL=founder@thunity.local
FOUNDER_PASSWORD=CHANGE_ME

# ── Local models (Ollama). 7B/8B defaults for RX 6600 XT 8GB + 16GB RAM ──
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL_FAST=qwen2.5:7b-instruct
OLLAMA_MODEL_ANALYST=qwen2.5:7b-instruct
OLLAMA_MODEL_CRITIC=llama3.1:8b
OLLAMA_MODEL_EXECUTION=qwen2.5-coder:7b
OLLAMA_MODEL_SYNTHESIZER=qwen2.5:7b-instruct
OLLAMA_MODEL_EVALUATOR=qwen2.5:7b-instruct
OLLAMA_MODEL_EMBEDDING=nomic-embed-text
# Optional/manual deep reasoning — heavy, warns before use. Never auto-selected.
OLLAMA_MODEL_DEEP_REASONING=qwen2.5:14b-instruct

AGENT_EXECUTION_MODE=sequential
MAX_PARALLEL_AGENT_RUNS=1
MAX_CONTEXT_CHUNKS=5
MAX_AGENT_TIMEOUT_SECONDS=240
OLLAMA_NUM_CTX=4096

POSTGRES_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/thunity_ai
REDIS_URL=redis://redis:6379

FILES_DIR=/data/files
KNOWLEDGE_DIR=/data/knowledge
SANDBOX_DIR=/data/sandbox_runs
BACKUP_DIR=/data/backups
MAX_UPLOAD_MB=50

N8N_URL=http://n8n:5678
N8N_ENABLED=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# Optional legacy adapter — leave false. Blocked under LOCAL_ONLY_MODE anyway.
ENABLE_SUPABASE_ADAPTER=false
