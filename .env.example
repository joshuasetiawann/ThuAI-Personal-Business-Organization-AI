# ── Thunity Local AI Company OS — LOCAL-ONLY environment template ──
# Copy to .env and replace every CHANGE_ME. NEVER commit the real .env.
# By DEFAULT this is 100% local: no cloud keys are set and LOCAL_ONLY_MODE=true
# hard-disables every external AI path. The OPTIONAL, off-by-default frontier
# (cloud) lane is documented near the bottom of this file — read it before
# enabling it, because turning it on sends prompts + grounded context off-machine.
#
# Most variables below are LOCAL-DEV DEFAULTS. They are safe for a developer
# machine or Joshua's Linux box. Before any non-local use, rotate every
# CHANGE_ME and set APP_ENV=production (the backend hard-blocks insecure
# defaults in production — see backend/config.py:startup_safety_check).
#
# ── Variable naming note (read this if a guide used different names) ──
# Some external guides use generic names. THIS project's canonical names are:
#   SECRET_KEY            (NOT JWT_SECRET)
#   JWT_EXPIRE_MINUTES    (NOT ACCESS_TOKEN_EXPIRE_MINUTES)
#   ALLOWED_ORIGINS       (NOT CORS_ORIGINS)
#   OLLAMA_URL            (NOT OLLAMA_HOST)
#   OLLAMA_MODEL_FAST     (NOT OLLAMA_MODEL)
#   OLLAMA_MODEL_EMBEDDING(NOT OLLAMA_EMBED_MODEL)
#   POSTGRES_URL          (NOT DATABASE_URL)
# Aliases are listed in comments below only so they are easy to find; the
# backend reads the canonical names. Setting an alias alone does nothing.

APP_ENV=development
LOCAL_ONLY_MODE=true

# ── Security (LOCAL DEV defaults — rotate before any shared/prod use) ──
# Generate a strong value with:  openssl rand -hex 32
# In development a missing/default SECRET_KEY is replaced by a random EPHEMERAL
# secret at startup (the app boots, but every restart logs everyone out). In
# production a default/missing SECRET_KEY refuses to boot.
SECRET_KEY=change-this-with-strong-random-secret      # alias: JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                                # alias: ACCESS_TOKEN_EXPIRE_MINUTES
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated browser origins allowed to call the API (LOCAL DEV list).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://localhost:8080,http://localhost:8000
# alias: CORS_ORIGINS  (use ALLOWED_ORIGINS above; this line is documentation only)

# First founder is bootstrapped from these (no hardcoded admin/admin123).
FOUNDER_EMAIL=founder@thunity.local
FOUNDER_PASSWORD=CHANGE_ME

# ── Postgres ──────────────────────────────────────────────────────────
# REQUIRED by docker-compose.yml: compose refuses to start without this.
# It is injected into the backend's POSTGRES_URL automatically by compose.
POSTGRES_USER=postgres                                  # LOCAL DEV default
POSTGRES_DB=thunity_ai                                  # LOCAL DEV default
POSTGRES_PASSWORD=CHANGE_ME_strong_local_password      # REQUIRED — LOCAL DEV
# Direct DB URL used when running the backend OUTSIDE Docker (local python).
# Inside Docker, compose overrides this from POSTGRES_PASSWORD above.
# Keep the password here identical to POSTGRES_PASSWORD.
POSTGRES_URL=postgresql+asyncpg://postgres:CHANGE_ME_strong_local_password@postgres:5432/thunity_ai
# alias: DATABASE_URL  (use POSTGRES_URL above; documentation only)

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Ollama / models (all local) ──────────────────────────────────────
# OLLAMA_URL tells the backend where Ollama lives:
#   • Docker + container Ollama (default / Linux ROCm):  http://ollama:11434
#   • Mac/host Ollama from a backend container:          http://host.docker.internal:11434
#   • Backend running directly on the host (no Docker):  http://localhost:11434
OLLAMA_URL=http://ollama:11434                          # alias: OLLAMA_HOST
OLLAMA_MODEL_FAST=qwen2.5:7b-instruct                  # alias: OLLAMA_MODEL
OLLAMA_MODEL_ANALYST=qwen2.5:7b-instruct
OLLAMA_MODEL_CRITIC=llama3.1:8b
OLLAMA_MODEL_EXECUTION=qwen2.5-coder:7b
OLLAMA_MODEL_SYNTHESIZER=qwen2.5:7b-instruct
OLLAMA_MODEL_EVALUATOR=qwen2.5:7b-instruct
OLLAMA_MODEL_EMBEDDING=nomic-embed-text                # alias: OLLAMA_EMBED_MODEL
# Optional/manual deep reasoning — heavy, warns before use. Never auto-selected.
OLLAMA_MODEL_DEEP_REASONING=qwen2.5:14b-instruct

AGENT_EXECUTION_MODE=sequential
MAX_PARALLEL_AGENT_RUNS=1
MAX_CONTEXT_CHUNKS=5
MAX_AGENT_TIMEOUT_SECONDS=240
OLLAMA_NUM_CTX=4096

FILES_DIR=/data/files
KNOWLEDGE_DIR=/data/knowledge
SANDBOX_DIR=/data/sandbox_runs
BACKUP_DIR=/data/backups
MAX_UPLOAD_MB=50

# ── n8n (local automation, governed) ─────────────────────────────────
N8N_URL=http://n8n:5678
N8N_ENABLED=true
# REQUIRED by docker-compose.yml (n8n basic auth). LOCAL DEV defaults:
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
# Optional n8n tuning — NOT currently wired into the backend/compose; the n8n
# container sets host/port internally. Left here for completeness only.
# N8N_HOST=0.0.0.0
# N8N_PORT=5678
# N8N_PROTOCOL=http
# WEBHOOK_URL=http://localhost:5678/

# Optional legacy adapter — leave false. Blocked under LOCAL_ONLY_MODE anyway.
ENABLE_SUPABASE_ADAPTER=false

# ── OPTIONAL frontier (cloud) AI — OFF by default ─────────────────────
# ⚠️  READ THIS. Enabling the frontier lane sends your prompts AND the grounded
# local memory/knowledge injected into them to a THIRD-PARTY cloud (Anthropic or
# OpenRouter). Free OpenRouter endpoints may even log/train on that data. Every
# frontier answer is labelled in the UI, but the data still leaves your machine.
#
# To actually use it, ALL THREE must be true (so a stray ambient key can never
# silently route your data to the cloud):
#   1) FRONTIER_ENABLED=true
#   2) a key is set below
#   3) LOCAL_ONLY_MODE=false   (the master switch above — it gates this lane)
# With LOCAL_ONLY_MODE=true (the default), the frontier lane is hard-disabled
# even if a key is present.
FRONTIER_ENABLED=false
# FRONTIER_PROVIDER=auto            # auto | anthropic | openrouter
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free   # verify slug at openrouter.ai/models
